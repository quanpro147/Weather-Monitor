# Data pipeline — direct PostgreSQL connection (data-pipeline/fetchers/)
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=

# Supabase (server-side — FastAPI)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (client-side — Next.js frontend)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# FastAPI URL (client-side — Next.js frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Redis
# Dùng REDIS_HOST=redis khi chạy trong Docker, localhost khi dev local
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# App
APP_ENV=development
APP_PORT=8000

# LLM
OPENAI_API_KEY=
GEMINI_API_KEY=

